services:
  gluetun:
    cap_add:
      - NET_ADMIN
    container_name: gluetun
    devices:
      - /dev/net/tun
    environment:
      - VPN_SERVICE_PROVIDER=REDACTED
      - OPENVPN_USER=REDACTED
      - OPENVPN_PASSWORD=REDACTED
      - SERVER_COUNTRIES=REDACTED
      - TZ=REDACTED
      - FIREWALL_VPN_INPUT_PORTS=
      - DOT=on
      - PUBLIC_DNS=enabled
      - BLOCK_MALICIOUS=on
      - HTTP_PROXY=off
    image: qmcgaw/gluetun:latest
    ports:
      - '8080:8080'
      - '30025:7878'
      - '30050:9696'
      - '30113:8989'
    restart: always
  REDACTED_SERVICE_01:
    container_name: REDACTED
    depends_on:
      - gluetun
    environment:
      - PUID=568
      - PGID=568
      - TZ=REDACTED
    image: lscr.io/linuxserver/REDACTED:latest
    network_mode: service:gluetun
    restart: unless-stopped
    volumes:
      - /mnt/Apps/REDACTED:/config
  REDACTED_SERVICE_02:
    container_name: REDACTED
    depends_on:
      - gluetun
    environment:
      - PUID=568
      - PGID=568
      - TZ=REDACTED
      - WEBUI_PORT=8080
    image: lscr.io/linuxserver/REDACTED:latest
    network_mode: service:gluetun
    restart: unless-stopped
    volumes:
      - /mnt/Apps/Gluetun-REDACTED:/config
      - /mnt/Storage_Media/REDACTED/REDACTED:/REDACTED
  REDACTED_SERVICE_03:
    container_name: REDACTED
    depends_on:
      - gluetun
    environment:
      - PUID=568
      - PGID=568
      - TZ=REDACTED
    image: lscr.io/linuxserver/REDACTED:latest
    network_mode: service:gluetun
    restart: unless-stopped
    volumes:
      - /mnt/Apps/REDACTED:/config
      - /mnt/Storage_Media/REDACTED/REDACTED:/REDACTED
      - /mnt/Storage_Media/REDACTED/REDACTED:/REDACTED
  REDACTED_SERVICE_04:
    container_name: REDACTED
    depends_on:
      - gluetun
    environment:
      - PUID=568
      - PGID=568
      - TZ=REDACTED
    image: lscr.io/linuxserver/REDACTED:latest
    network_mode: service:gluetun
    restart: unless-stopped
    volumes:
      - /mnt/Apps/REDACTED:/config
      - /mnt/Storage_Media/REDACTED/REDACTED:/REDACTED
      - /mnt/Storage_Media/REDACTED/REDACTED:/REDACTED
      - /mnt/Storage_Media/REDACTED/REDACTED:/REDACTED

<group name="rootcheck,">
  <rule id="100002" level="0">
    <if_sid>510</if_sid>
    <match>/bin/diff|/usr/bin/diff</match>
    <description>False positive - diff binary triggers generic trojan signature</description>
  </rule>
  <rule id="100003" level="0">
    <if_sid>510</if_sid>
    <match>NTFS Alternate data stream found</match>
    <field name="data.title" type="pcre2">\\WINDOWS\\tracing</field>
    <description>False positive - NTFS ADS on Windows tracing directory</description>
  </rule>
</group>

<group name="windows,sysmon,">
  <rule id="100001" level="0">
    <if_sid>61618</if_sid>
    <field name="win.eventdata.parentProcessGuid" type="pcre2">^\{00000000-0000-0000-0000-000000000000\}$</field>
    <description>False positive - svchost null parent GUID is a Sysmon boot-time artifact</description>
  </rule>
  <rule id="100004" level="0">
    <if_sid>92213</if_sid>
    <field name="win.eventdata.targetFilename" type="pcre2">__PSScriptPolicyTest_</field>
    <description>False positive - PowerShell script policy test file</description>
  </rule>
  <rule id="100005" level="0">
    <if_sid>92058</if_sid>
    <field name="win.eventdata.image">C:\\Windows\\System32\\sdbinst.exe</field>
    <field name="win.eventdata.parentImage">C:\\Windows\\System32\\svchost.exe</field>
    <field name="win.eventdata.parentCommandLine" type="pcre2">.*PcaSvc</field>
    <description>False positive - Windows Application Compatibility updates</description>
  </rule>
  <rule id="100006" level="0">
    <if_sid>92213</if_sid>
    <field name="win.eventdata.image" type="pcre2">Microsoft VS Code\\Code\.exe</field>
    <description>False positive - VS Code dropping temp task files</description>
  </rule>
  <rule id="100007" level="0">
    <if_sid>92213</if_sid>
    <field name="win.eventdata.targetFilename" type="pcre2">BEClient2\.dll</field>
    <description>False positive - BattleEye anti-cheat DLL</description>
  </rule>
</group>
<group name="local,custom_security,">

  <rule id="100010" level="7">
    <if_sid>5715</if_sid>
    <match>Fail2Ban</match>
    <description>Security Event: Edge firewall actively banned an IP address via Fail2Ban.</description>
    <group>active_response,firewall_mitigation,</group>
  </rule>

  <rule id="100011" level="10">
    <if_sid>5402</if_sid>
    <match>invalid password|unauthorized access|login failed</match>
    <description>High Alert: Multiple authentication failures detected on containerized administrative interfaces.</description>
    <group>authentication_failure,brute_force,</group>
  </rule>

</group>
